# Domain Configuration
MONOPOLY_DOMAIN=localhost
PROTOCOL=http

# 路径前缀配置（留空=端口模式，设置后使用 nginx 路径反代）
# API_BASE_PREFIX=/monopoly-server
# ICE_BASE_PREFIX=/monopoly-ice （留空跟随 API_BASE_PREFIX）
# ADMIN_BASE_PREFIX=/monopoly-admin （留空跟随 API_BASE_PREFIX）
API_BASE_PREFIX=
ICE_BASE_PREFIX=
ADMIN_BASE_PREFIX=

# Server Ports
SERVER_PORT=81
ICE_SERVER_PORT=82
MONOPOLY_ADMIN_PORT=80

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=monopoly
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# Environment
NODE_ENV=development

# TURN Server Configuration
TURN_SECRET=your-random-secret-key-change-in-production
TURN_TTL=86400
TURN_URL=localhost
TURN_PORT=5349
STUN_PORT=3478

# Optional: Tencent Cloud COS Configuration
# TC_ID=
# TC_KEY=
# TC_BUCKET_NAME=
# TC_REGION=

# 文件存储路径配置
# AVATAR_STORAGE_PATH=user/avatars
# GAME_MAP_STORAGE_PATH=monopoly/game-map
