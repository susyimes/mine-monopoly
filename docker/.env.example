# 域名配置
MONOPOLY_DOMAIN=localhost
PROTOCOL=http

# 路径前缀配置（留空=端口模式，设置后使用 nginx 路径反代）
# API_BASE_PREFIX=/monopoly-server
# ICE_BASE_PREFIX=/monopoly-ice （留空跟随 API_BASE_PREFIX）
# ADMIN_BASE_PREFIX=/monopoly-admin （已改用独立端口模式，此配置不再使用）
API_BASE_PREFIX=
ICE_BASE_PREFIX=
ADMIN_BASE_PREFIX=

# 服务端口
SERVER_PORT=81
ICE_SERVER_PORT=82
MONOPOLY_ADMIN_PORT=83

# MySQL 配置
MYSQL_HOST=fatpaper-mysql
MYSQL_PORT=3306
MYSQL_DATABASE=monopoly
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# 运行环境
NODE_ENV=development

# TURN 服务器配置
TURN_SECRET=your-random-secret-key-change-in-production
TURN_TTL=86400
TURN_URL=localhost
TURN_PORT=5349
STUN_PORT=3478

# Coturn 指标采集地址（服务端通过此地址获取 Prometheus 指标）
COTURN_METRICS_URL=http://monopoly-coturn:9641/metrics

# 可选：腾讯云 COS 配置
# TC_ID=
# TC_KEY=
# TC_BUCKET_NAME=
# TC_REGION=

# 文件存储路径配置
AVATAR_STORAGE_PATH=monopoly/user-avatar
GAME_MAP_STORAGE_PATH=monopoly/game-map
