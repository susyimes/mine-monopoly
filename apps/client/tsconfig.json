{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"useDefineForClassFields": true,
		"strict": true,
		"jsx": "preserve",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"lib": ["ESNext", "DOM"],
		"noEmit": true,
		"baseUrl": "./",
		"paths": {
			"@src/*": ["src/*"]
		}
	},
	"include": ["src/**/*", "electron/**/*", "types/**/*", "env/*.d.ts"],
	"exclude": ["node_modules"]
}
